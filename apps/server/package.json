{
  "name": "@kusinakonek/server",
  "version": "0.0.1",
  "private": true,
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:check": "ts-node-dev --transpile-only --exit-child src/scripts/check_db_connections.ts",
    "db:generate": "npx dotenv -e ../../.env -- prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "npx dotenv -e ../../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "db:push": "npx dotenv -e ../../.env -- prisma db push --schema=prisma/schema.prisma",
    "db:studio": "npx dotenv -e ../../.env -- prisma studio --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@kusinakonek/common": "*",
    "@kusinakonek/database": "*",
    "@prisma/client": "^5.20.0",
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.11",
    "prisma": "^5.20.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}