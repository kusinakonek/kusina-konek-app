{
  "expo": {
    "name": "kusinakonek",
    "slug": "kusinakonek",
    "scheme": "kusinakonek",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/KusinaKonek-Logo.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.kusinakonek.kusinakonek"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "6a2f5ed2-73f4-47cc-b874-fae39698337d"
      }
    }
  }
}