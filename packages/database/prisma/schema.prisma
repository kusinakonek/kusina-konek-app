generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  roleID      Int      @id @default(autoincrement())
  roleName    String   @unique
  users       User[]
}

model Status {
  statusID    Int      @id @default(autoincrement())
  statusName  String   @unique
}

model User {
  userID      String   @id @default(uuid())
  roleID      Int?
  role        Role?    @relation(fields: [roleID], references: [roleID])
  firstName   String
  middleName  String?
  lastName    String
  suffix      String?
  phoneNo     String
  phoneNoHash String   @unique
  email       String
  emailHash   String   @unique
  isOrg       Boolean  @default(false)
  orgName     String?
  password    String
  pushToken   String?  // Expo push token for push notifications
  averageRating Float    @default(0)
  ratingCount   Int      @default(0)
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime @default(now())
  DateAdded     DateTime @default(now())

  // Relations
  foods           Food[]
  userAddress     Address?
  dropOffLocations DropOffLocation[]
  
  // Distribution relations
  donations       Distribution[] @relation("DonorDistributions")
  received        Distribution[] @relation("RecipientDistributions")
  
  // Feedback relations
  givenFeedback   Feedback[] @relation("DonorFeedbacks")
  receivedFeedback Feedback[] @relation("RecipientFeedbacks")
  
  // Notification relations
  notifications   Notification[]

  @@index([emailHash])
  @@index([phoneNoHash])
}

model Notification {
  notificationID String   @id @default(uuid())
  userID         String
  user           User     @relation(fields: [userID], references: [userID])
  type           String   // e.g., "CLAIM_ALERT"
  title          String
  message        String
  isRead         Boolean  @default(false)
  entityID       String?  // e.g. disID or foodID
  createdAt      DateTime @default(now())
  
  @@index([userID])
  @@index([isRead])
}



model Address {
  addID         String   @id @default(uuid())
  UserID        String   @unique // One address per user?
  user          User     @relation(fields: [UserID], references: [userID])
  latitude      Float
  longitude     Float
  streetAddress String
  barangay      String
}

model Food {
  foodID        String   @id @default(uuid())
  userID        String
  user          User     @relation(fields: [userID], references: [userID])
  foodName      String
  dateCooked    DateTime?
  description   String?
  quantity      String
  image         String?
  availabilityDuration Int? @default(240) // Duration in minutes, default 4 hours
  expireAt      DateTime? // The exact time when this food expires and should be cancelled
  timestamp     DateTime @default(now())

  // Relations
  locations     DropOffLocation[]
  distributions Distribution[]
}

model DropOffLocation {
  locID         String   @id @default(uuid())
  foodID        String?  // Optional in case location manages multiple or none initially? Diagram says it has it.
  food          Food?    @relation(fields: [foodID], references: [foodID])
  userID        String
  user          User     @relation(fields: [userID], references: [userID])
  latitude      Float
  longitude     Float
  streetAddress String
  barangay      String?
  
  distributions Distribution[]
}

enum DistributionStatus {
  PENDING
  CLAIMED
  ON_THE_WAY
  DELIVERED
  COMPLETED
}

model Distribution {
  disID         String   @id @default(uuid())
  donorID       String
  donor         User     @relation("DonorDistributions", fields: [donorID], references: [userID])
  recipientID   String?
  recipient     User?    @relation("RecipientDistributions", fields: [recipientID], references: [userID])
  locID         String
  location      DropOffLocation @relation(fields: [locID], references: [locID])
  foodID        String
  food          Food     @relation(fields: [foodID], references: [foodID])
  quantity      String
  status        DistributionStatus @default(PENDING)
  photoProof    String?
  scheduledTime DateTime
  actualTime    DateTime?
  timestamp     DateTime @default(now())
  claimedAt     DateTime?
  
  feedbacks     Feedback[]
  
  @@index([donorID, status])
  @@index([recipientID, claimedAt])
  @@index([status, recipientID])
  @@index([timestamp])
}

model Feedback {
  feedbackID    String   @id @default(uuid())
  donorID       String
  donor         User     @relation("DonorFeedbacks", fields: [donorID], references: [userID])
  recipientID   String
  recipient     User     @relation("RecipientFeedbacks", fields: [recipientID], references: [userID])
  disID         String
  distribution  Distribution @relation(fields: [disID], references: [disID])
  ratingScore   Int
  
  @@index([donorID])
  @@index([disID])
  comments      String?
  photoUrl      String?
  timestamp     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
