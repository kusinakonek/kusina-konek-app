# =============================================
# Kusina Konek - Environment Configuration
# =============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# IMPORTANT: .env is gitignored — each team member needs their own copy.

# Server Configuration
PORT=3000
CORS_ORIGIN=*

# Supabase Configuration
# Get these from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database URL from Supabase (Connection pooling for queries)
DATABASE_URL="postgresql://postgres.your-project:your-password@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for migrations
DIRECT_URL="postgresql://postgres.your-project:your-password@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# JWT Secret for additional token verification
JWT_SECRET=generate-a-random-uuid-here

# Encryption Key (64 hex characters = 32 bytes for AES-256)
ENCRYPTION_KEY=generate-a-64-char-hex-string-here-0000000000000000000000000000000000

# Mobile App API Configuration (OPTIONAL — auto-detected in dev!)
# The mobile app auto-detects your machine's IP from Expo.
# Only set these if auto-detection doesn't work for you:
# EXPO_PUBLIC_API_HOST=192.168.x.x
# EXPO_PUBLIC_API_PORT=3000

# Production API URL (only needed for APK builds)
# EXPO_PUBLIC_API_URL=https://your-deployed-backend.com
