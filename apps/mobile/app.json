{
  "expo": {
    "name": "kusinakonek",
    "slug": "kusinakonek",
    "scheme": "kusinakonek",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/KusinaKonek-Logo.png",
    "notification": {
      "icon": "./assets/KusinaKonek-Logo.png",
      "color": "#00C853"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyAOVYRIgupAurZup5y1PRh8Ismb1A3lLao"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of food donations.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload food donation images."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAOVYRIgupAurZup5y1PRh8Ismb1A3lLao"
        }
      },
      "package": "com.kusinakonek.kusinakonek",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-location",
      [
        "expo-notifications",
        {
          "android": {
            "usesFCMV1": true
          }
        }
      ],
      "expo-image-picker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d8943c07-cbc7-4ae8-86a2-783ff4283c00"
      },
      "router": {}
    },
    "owner": "testproject73s-organization"
  }
}