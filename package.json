{
  "name": "kusinakonek",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "npm --workspace apps/server run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "typecheck": "npm --workspace apps/server run typecheck",
    "db:generate": "npm --workspace packages/database run generate",
    "db:migrate": "npm --workspace packages/database run migrate",
    "db:push": "npm --workspace packages/database run push",
    "db:studio": "npm --workspace packages/database run studio",
    "db:seed": "npm --workspace packages/database run seed"
  },
  "devDependencies": {
    "@types/react": "~19.0.10"
  },
  "dependencies": {
    "expo-cli": "^6.3.12"
  }
}
